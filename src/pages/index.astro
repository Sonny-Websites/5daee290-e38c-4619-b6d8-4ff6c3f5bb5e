---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Temporary placeholder — Investigating site recovery"
  description="Temporary placeholder while site recovery and backups are being investigated."
  includeSiteScript={false}
  appendSiteName={false}
>
  <main class="placeholder" role="main" aria-labelledby="placeholderHeading">
    <h1 id="placeholderHeading">We're investigating site recovery</h1>
    <p>
      This is a temporary placeholder while we investigate recovery and backups for the original site. We are working to restore the site as quickly as possible. Please check back soon.
    </p>
    <small>Temporary placeholder</small>
  </main>
</BaseLayout>
